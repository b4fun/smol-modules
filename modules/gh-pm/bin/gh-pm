#!/usr/bin/env bash
set -euo pipefail

# gh-pm — GitHub Project Manager agent
# Polls GitHub for assigned tasks, analyzes them with an LLM,
# dispatches workflows, and reports status.

show_usage() {
  cat <<'EOF'
Usage: gh-pm [OPTIONS]

Options:
  --config PATH      Config file (default: ~/.gh-pm/gh-pm.toml, or $GH_PM_CONFIG)
  --workspace PATH   Workspace dir (default: ~/.gh-pm/workspace, or $GH_PM_WORKSPACE)
  --dry-run          No side effects — print what would happen
  --once             Run one poll cycle then exit
  --help             Show this help
EOF
}

# --- CLI parsing ---
ONCE=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)    shift; export GH_PM_CONFIG="$1"; shift ;;
    --workspace) shift; export GH_PM_WORKSPACE="$1"; shift ;;
    --dry-run)   export GH_PM_DRY_RUN=1; shift ;;
    --once)      ONCE=1; shift ;;
    --help|-h)   show_usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; show_usage >&2; exit 1 ;;
  esac
done

# --- Resolve paths ---
GH_PM_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && cd .. && pwd)"
export GH_PM_DIR
export GH_PM_CONFIG="${GH_PM_CONFIG:-$HOME/.gh-pm/gh-pm.toml}"
export GH_PM_WORKSPACE="${GH_PM_WORKSPACE:-$HOME/.gh-pm/workspace}"
export GH_PM_DRY_RUN="${GH_PM_DRY_RUN:-0}"

# --- Source libraries ---
for lib in "$GH_PM_DIR"/lib/*.sh; do
  # shellcheck source=/dev/null
  source "$lib"
done

# --- Initialize ---
config_load
log_init
mkdir -p "$GH_PM_WORKSPACE"

# Resolve authenticated GitHub user for filtering authored PRs
GH_PM_USER="$(gh api user --jq '.login' 2>/dev/null || echo '')"

log_info "main" "gh-pm starting (config=$GH_PM_CONFIG workspace=$GH_PM_WORKSPACE dry_run=$GH_PM_DRY_RUN)"

# --- Startup recovery ---
log_info "main" "Running startup recovery"
recovery_run

# --- Helpers ---

# process_item REPO TYPE ITEM_JSON
# TYPE: "issue" or "pr"
# ITEM_JSON: single object from gh poll output
process_item() {
  local repo="$1" type="$2" item_json="$3"

  local number title body labels_csv
  number="$(echo "$item_json" | jq -r '.number')"
  title="$(echo "$item_json" | jq -r '.title // ""')"
  body="$(echo "$item_json" | jq -r '.body // ""')"
  labels_csv="$(echo "$item_json" | jq -r '[.labels[]?.name // empty] | join(",")')"

  # Derive task ID
  local owner repo_name task_id task_dir
  owner="${repo%%/*}"
  repo_name="${repo#*/}"
  task_id="${owner}-${repo_name}-${type}-${number}"
  task_dir="${GH_PM_WORKSPACE}/${task_id}"

  # Skip if already tracked locally
  if [[ -d "$task_dir" ]]; then
    log_debug "poll" "Already tracked: $task_id"
    return 0
  fi

  # Skip if tracking comment already exists on GitHub
  local existing_comment
  existing_comment="$(gh_find_tracking_comment "$repo" "$number" "$task_id")"
  if [[ -n "$existing_comment" ]]; then
    log_debug "poll" "Tracking comment exists: $task_id"
    return 0
  fi

  log_info "poll" "New $type: $repo#$number - $title"

  # Resolve LLM profile
  local profile
  profile="$(config_resolve_profile "$labels_csv")"
  log_info "analyze" "Using profile=$profile for $task_id"

  # Create task dir and init logging
  mkdir -p "$task_dir"
  log_task_init "$task_id"

  # Post early "analyzing" comment so the issue gets immediate feedback
  report_analyzing "$repo" "$number" "$task_id" "$profile" || true

  # Gather context: comments
  local comments_json
  comments_json="$(gh_get_comments "$repo" "$type" "$number")"
  local comments_text
  comments_text="$(echo "$comments_json" | jq -r '.[]? | "[\(.author.login // "unknown")] \(.body // "")"' 2>/dev/null || echo '')"

  # LLM analysis
  local system_prompt user_prompt
  if [[ "$type" == "issue" ]]; then
    system_prompt="You are a project manager agent. Analyze the following GitHub issue and break it down into actionable sub-tasks. Provide clear instructions for an automated workflow to execute. Respond with your analysis directly — do NOT use any tools, do NOT browse files, do NOT run commands. Just analyze the issue text and produce a plan."
  else
    system_prompt="You are a project manager agent. Analyze the following GitHub pull request and break it down into actionable review tasks. Provide clear instructions for an automated workflow to execute. Respond with your analysis directly — do NOT use any tools, do NOT browse files, do NOT run commands. Just analyze the PR text and produce a plan."
  fi

  user_prompt="Repository: ${repo}
${type^} #${number}: ${title}

Description:
${body}"

  if [[ -n "$comments_text" ]]; then
    user_prompt+="

Comments:
${comments_text}"
  fi

  local analysis
  if ! analysis="$(llm_call "$profile" "$system_prompt" "$user_prompt")"; then
    log_error "analyze" "LLM call failed for $task_id"
    rm -rf "$task_dir"
    log_task_reset
    return 0
  fi

  # Write task.json (matching design spec schema)
  local workflow_policy
  workflow_policy="$(config_get_setting workflow_policy)"

  jq -n \
    --arg id "$task_id" \
    --arg source_type "$type" \
    --arg source_repo "$repo" \
    --argjson source_number "$number" \
    --arg source_url "$(echo "$item_json" | jq -r '.url // ""')" \
    --arg title "$title" \
    --arg body "$body" \
    --arg analysis "$analysis" \
    --arg policy "$workflow_policy" \
    --arg created_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      id: $id,
      source: {type: $source_type, repo: $source_repo, number: $source_number, url: $source_url},
      title: $title,
      body: $body,
      analysis: $analysis,
      policy: $policy,
      created_at: $created_at
    }' > "$task_dir/task.json"

  # Dispatch workflow
  if dispatch_task "$task_dir"; then
    report_dispatch "$repo" "$number" "$task_id" || true
  else
    log_error "dispatch" "Failed to dispatch $task_id"
    rm -rf "$task_dir"
  fi

  log_task_reset
}

# monitor_inflight — check all in-flight tasks.
monitor_inflight() {
  for task_dir in "$GH_PM_WORKSPACE"/*/; do
    [[ ! -d "$task_dir" ]] && continue
    [[ ! -f "$task_dir/task.json" ]] && continue
    [[ ! -f "$task_dir/dispatch.json" ]] && continue
    [[ -f "$task_dir/result.json" ]] && continue  # already done

    local task_id repo number
    task_id="$(basename "$task_dir")"
    repo="$(jq -r '.source.repo // empty' "$task_dir/task.json")"
    number="$(jq -r '.source.number // empty' "$task_dir/task.json")"
    [[ -z "$repo" || -z "$number" ]] && continue

    log_task_init "$task_id"

    local status
    status="$(dispatch_check_status "$task_dir")"

    case "$status" in
      done)
        log_info "monitor" "Task $task_id completed"
        report_completion "$repo" "$number" "$task_id" "$task_dir/result.json" || true
        ;;
      failed)
        log_warn "monitor" "Task $task_id failed"
        local err=""
        [[ -f "$task_dir/result.json" ]] && err="$(jq -r '.error // "Unknown error"' "$task_dir/result.json")"
        report_failure "$repo" "$number" "$task_id" "${err:-Workflow process exited without result}" || true
        ;;
      timeout)
        log_warn "monitor" "Task $task_id timed out"
        local attempt max_retries
        attempt="$(jq -r '.attempt // 1' "$task_dir/dispatch.json")"
        max_retries="$(config_get_setting max_retries)"
        max_retries="${max_retries:-3}"
        report_timeout "$repo" "$number" "$task_id" "$attempt" "$max_retries" || true
        dispatch_handle_timeout "$task_dir" || true
        ;;
      running)
        # Check for status.json updates
        if [[ -f "$task_dir/status.json" ]]; then
          local msg
          msg="$(jq -r '.message // ""' "$task_dir/status.json" 2>/dev/null)"
          if [[ -n "$msg" ]]; then
            log_debug "monitor" "Task $task_id status: $msg"
            report_status "$repo" "$number" "$task_id" "$msg" || true
          fi
        fi
        ;;
    esac

    log_task_reset
  done
}

# process_pr_reviews REPO ITEM_JSON
# Check for CHANGES_REQUESTED reviews on an authored PR and dispatch a fix task.
process_pr_reviews() {
  local repo="$1" item_json="$2"

  local number title body labels_csv
  number="$(echo "$item_json" | jq -r '.number')"
  title="$(echo "$item_json" | jq -r '.title // ""')"
  body="$(echo "$item_json" | jq -r '.body // ""')"
  labels_csv="$(echo "$item_json" | jq -r '[.labels[]?.name // empty] | join(",")')"

  local owner repo_name
  owner="${repo%%/*}"
  repo_name="${repo#*/}"

  # Get CHANGES_REQUESTED reviews
  local reviews
  reviews="$(gh_get_pending_reviews "$repo" "$number")"
  local review_count
  review_count="$(echo "$reviews" | jq 'length')"
  [[ "$review_count" -eq 0 ]] && return 0

  # Process each review — use review ID in task ID to avoid re-processing
  for (( ri=0; ri<review_count; ri++ )); do
    local review review_id review_body reviewer
    review="$(echo "$reviews" | jq ".[$ri]")"
    review_id="$(echo "$review" | jq -r '.id')"
    review_body="$(echo "$review" | jq -r '.body // ""')"
    reviewer="$(echo "$review" | jq -r '.user.login // "unknown"')"

    local task_id="${owner}-${repo_name}-pr-${number}-review-${review_id}"
    local task_dir="${GH_PM_WORKSPACE}/${task_id}"

    # Skip if already tracked
    if [[ -d "$task_dir" ]]; then
      log_debug "poll" "Already tracked: $task_id"
      continue
    fi
    if [[ -n "$(gh_find_tracking_comment "$repo" "$number" "$task_id")" ]]; then
      log_debug "poll" "Tracking comment exists: $task_id"
      continue
    fi

    log_info "poll" "New review feedback: $repo#$number review=$review_id by $reviewer"

    # Also fetch inline review comments
    local review_comments_text=""
    if [[ "${GH_PM_DRY_RUN:-0}" != "1" ]]; then
      review_comments_text="$(gh api "/repos/${repo}/pulls/${number}/reviews/${review_id}/comments" 2>/dev/null \
        | jq -r '.[]? | "[\(.path // \"\"):\(.line // \"\")] \(.body // \"\")"' 2>/dev/null || echo '')"
    fi

    # Resolve LLM profile
    local profile
    profile="$(config_resolve_profile "$labels_csv")"
    log_info "analyze" "Using profile=$profile for $task_id"

    mkdir -p "$task_dir"
    log_task_init "$task_id"

    # Post analyzing comment
    report_analyzing "$repo" "$number" "$task_id" "$profile" || true

    # Build review context
    local review_context="Review by @${reviewer} (CHANGES_REQUESTED):
${review_body}"
    if [[ -n "$review_comments_text" ]]; then
      review_context+="

Inline comments:
${review_comments_text}"
    fi

    # LLM analysis
    local system_prompt="You are a project manager agent. A pull request has received review feedback requesting changes. Analyze the feedback and produce clear instructions for an automated workflow to address the reviewer's comments. Respond with your analysis directly — do NOT use any tools, do NOT browse files, do NOT run commands."
    local user_prompt="Repository: ${repo}
PR #${number}: ${title}

PR Description:
${body}

${review_context}

Produce a plan to address the review feedback."

    local analysis
    if ! analysis="$(llm_call "$profile" "$system_prompt" "$user_prompt")"; then
      log_error "analyze" "LLM call failed for $task_id"
      rm -rf "$task_dir"
      log_task_reset
      continue
    fi

    # Write task.json
    local workflow_policy
    workflow_policy="$(config_get_setting workflow_policy)"

    jq -n \
      --arg id "$task_id" \
      --arg source_type "pr-review" \
      --arg source_repo "$repo" \
      --argjson source_number "$number" \
      --arg source_url "$(echo "$item_json" | jq -r '.url // ""')" \
      --arg title "$title" \
      --arg body "$body" \
      --arg review_context "$review_context" \
      --arg analysis "$analysis" \
      --arg policy "$workflow_policy" \
      --arg created_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      '{
        id: $id,
        source: {type: $source_type, repo: $source_repo, number: $source_number, url: $source_url},
        title: $title,
        body: $body,
        review_context: $review_context,
        analysis: $analysis,
        policy: $policy,
        created_at: $created_at
      }' > "$task_dir/task.json"

    if dispatch_task "$task_dir"; then
      report_dispatch "$repo" "$number" "$task_id" || true
    else
      log_error "dispatch" "Failed to dispatch $task_id"
      rm -rf "$task_dir"
    fi

    log_task_reset
  done
}

# process_pr_ci_failures REPO ITEM_JSON
# Check for failed CI checks on an authored PR and dispatch a fix task.
process_pr_ci_failures() {
  local repo="$1" item_json="$2"

  if [[ "${GH_PM_DRY_RUN:-0}" == "1" ]]; then
    return 0
  fi

  local number title body labels_csv
  number="$(echo "$item_json" | jq -r '.number')"
  title="$(echo "$item_json" | jq -r '.title // ""')"
  body="$(echo "$item_json" | jq -r '.body // ""')"
  labels_csv="$(echo "$item_json" | jq -r '[.labels[]?.name // empty] | join(",")')"

  local owner repo_name
  owner="${repo%%/*}"
  repo_name="${repo#*/}"

  # Get the head commit SHA
  local head_sha
  head_sha="$(gh pr view "$number" --repo "$repo" --json headRefOid -q .headRefOid 2>/dev/null)"
  [[ -z "$head_sha" ]] && return 0

  # Get failed check runs
  local failed_checks
  failed_checks="$(gh api "repos/${repo}/commits/${head_sha}/check-runs" 2>/dev/null \
    | jq '[.check_runs[] | select(.status == "completed" and .conclusion == "failure")]' 2>/dev/null || echo '[]')"
  local fail_count
  fail_count="$(echo "$failed_checks" | jq 'length')"
  [[ "$fail_count" -eq 0 ]] && return 0

  # Use head SHA in task ID so we only process failures once per push
  local short_sha="${head_sha:0:7}"
  local task_id="${owner}-${repo_name}-pr-${number}-ci-${short_sha}"
  local task_dir="${GH_PM_WORKSPACE}/${task_id}"

  # Skip if already tracked
  if [[ -d "$task_dir" ]]; then
    log_debug "poll" "Already tracked: $task_id"
    return 0
  fi
  if [[ -n "$(gh_find_tracking_comment "$repo" "$number" "$task_id")" ]]; then
    log_debug "poll" "Tracking comment exists: $task_id"
    return 0
  fi

  # Build failure summary
  local failure_summary=""
  for (( fi=0; fi<fail_count; fi++ )); do
    local check_name check_url
    check_name="$(echo "$failed_checks" | jq -r ".[$fi].name")"
    check_url="$(echo "$failed_checks" | jq -r ".[$fi].html_url // \"\"")"
    failure_summary+="- **${check_name}**"
    [[ -n "$check_url" ]] && failure_summary+=" ([logs](${check_url}))"
    failure_summary+=$'\n'
  done

  log_info "poll" "CI failure on $repo#$number ($fail_count check(s) failed, sha=$short_sha)"

  # Resolve LLM profile
  local profile
  profile="$(config_resolve_profile "$labels_csv")"
  log_info "analyze" "Using profile=$profile for $task_id"

  mkdir -p "$task_dir"
  log_task_init "$task_id"

  report_analyzing "$repo" "$number" "$task_id" "$profile" || true

  # LLM analysis
  local system_prompt="You are a project manager agent. A pull request has failing CI checks. Analyze the failures and produce clear instructions for an automated workflow to fix them. Respond with your analysis directly — do NOT use any tools, do NOT browse files, do NOT run commands."
  local user_prompt="Repository: ${repo}
PR #${number}: ${title}
Head commit: ${head_sha}

PR Description:
${body}

Failed CI checks:
${failure_summary}
Produce a plan to investigate and fix the CI failures. The workflow agent will have access to the repository and can run commands to diagnose and fix the issues."

  local analysis
  if ! analysis="$(llm_call "$profile" "$system_prompt" "$user_prompt")"; then
    log_error "analyze" "LLM call failed for $task_id"
    rm -rf "$task_dir"
    log_task_reset
    return 0
  fi

  # Write task.json
  local workflow_policy
  workflow_policy="$(config_get_setting workflow_policy)"

  jq -n \
    --arg id "$task_id" \
    --arg source_type "pr-ci" \
    --arg source_repo "$repo" \
    --argjson source_number "$number" \
    --arg source_url "$(echo "$item_json" | jq -r '.url // ""')" \
    --arg title "$title" \
    --arg body "$body" \
    --arg ci_failures "$failure_summary" \
    --arg analysis "$analysis" \
    --arg policy "$workflow_policy" \
    --arg created_at "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    '{
      id: $id,
      source: {type: $source_type, repo: $source_repo, number: $source_number, url: $source_url},
      title: $title,
      body: $body,
      ci_failures: $ci_failures,
      analysis: $analysis,
      policy: $policy,
      created_at: $created_at
    }' > "$task_dir/task.json"

  if dispatch_task "$task_dir"; then
    report_dispatch "$repo" "$number" "$task_id" || true
  else
    log_error "dispatch" "Failed to dispatch $task_id"
    rm -rf "$task_dir"
  fi

  log_task_reset
}

# --- Main loop ---
POLL_INTERVAL="$(config_get_setting poll_interval)"
POLL_INTERVAL="${POLL_INTERVAL:-60}"

mapfile -t REPOS < <(config_get_repos)
if [[ ${#REPOS[@]} -eq 0 ]]; then
  log_warn "main" "No repos configured in [settings] repos"
fi

while true; do
  log_debug "main" "Poll cycle starting"

  for repo in "${REPOS[@]}"; do
    [[ -z "$repo" ]] && continue
    log_debug "poll" "Polling $repo"

    # Issues
    issues_json="$(gh_poll_issues "$repo")"
    issue_count="$(echo "$issues_json" | jq 'length')"
    for (( i=0; i<issue_count; i++ )); do
      item="$(echo "$issues_json" | jq ".[$i]")"
      process_item "$repo" "issue" "$item"
    done

    # PRs
    prs_json="$(gh_poll_prs "$repo")"
    pr_count="$(echo "$prs_json" | jq 'length')"
    for (( i=0; i<pr_count; i++ )); do
      item="$(echo "$prs_json" | jq ".[$i]")"
      local pr_author
      pr_author="$(echo "$item" | jq -r '.author.login // ""')"
      if [[ "$pr_author" == "$GH_PM_USER" ]]; then
        # Authored PR — check for review feedback and CI failures
        process_pr_reviews "$repo" "$item"
        process_pr_ci_failures "$repo" "$item"
      else
        # Assigned/review-requested PR — process as new task
        process_item "$repo" "pr" "$item"
      fi
    done
  done

  # Monitor in-flight tasks
  monitor_inflight

  if [[ "$ONCE" -eq 1 ]]; then
    log_info "main" "--once mode, exiting after single cycle"
    break
  fi

  log_debug "main" "Sleeping ${POLL_INTERVAL}s"
  sleep "$POLL_INTERVAL"
done

log_info "main" "gh-pm stopped"
